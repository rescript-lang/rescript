{
  "lint": {
    "rules": {
      "forbidden-reference": {
        "severity": "error",
        "items": ["Belt.Array.forEach", "Belt.Array.map", "Js.Json.t"]
      },
      "single-use-function": {
        "severity": "warning"
      }
    }
  },
  "rewrite": {
    "rules": {
      "prefer-switch": {
        "enabled": true,
        "if": true,
        "ternary": true
      },
      "no-optional-some": {
        "enabled": true
      }
    }
  }
}
