path: src/rewrite/RewriteIfs.res
status: preview
rules:
- prefer-switch(4): rewrote `if` / ternary branches into `switch`
diff:
```diff
--- a/src/rewrite/RewriteIfs.res
+++ b/src/rewrite/RewriteIfs.res
@@ -1,21 +1,22 @@
 let flag = true
 let other = false

-let direct = if flag {
-  1
-} else {
-  2
+let direct = switch flag {
+| true => 1
+| false => 2
 }
-let ternary = flag ? "yes" : "no"
+let ternary = switch flag {
+| true => "yes"
+| false => "no"
+}

-let chained = if flag {
-  1
-} else if other {
-  2
-} else {
-  3
+let chained = switch () {
+| _ if flag => 1
+| _ if other => 2
+| _ => 3
 }

-let onlyWhen = if flag {
-  Console.log("hit")
+let onlyWhen = switch flag {
+| true => Console.log("hit")
+| false => ()
 }
```

path: src/rewrite/RewriteOptionalSome.res
