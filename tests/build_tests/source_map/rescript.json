{
  "name": "source_map",
  "sources": ["src"],
  "package-specs": [
    {
      "module": "commonjs",
      "in-source": true,
      "suffix": ".cjs"
    },
    {
      "module": "esmodule",
      "in-source": true,
      "suffix": ".mjs"
    }
  ],
  "sourceMap": {
    "enabled": "always",
    "mode": "linked",
    "sourcesContent": true
  }
}
